<Project>
  <!--
    Remove DLLs from .azurefunctions that are already present in the main output directory.

    The Azure Functions Worker SDK loads .azurefunctions via an isolated AssemblyLoadContext
    (ALC). If a DLL exists in both the main output AND .azurefunctions, the process ends up with
    two distinct RuntimeTypeHandle values for the same type name — one from the default ALC, one
    from the isolated ALC. This causes type-identity mismatches: casts such as
    "context as HttpContext" silently return null even though the object is the correct type, and
    IInputConverter implementations return Unhandled() for types they should recognise.

    Deleting the overlapping DLLs from .azurefunctions forces the isolated ALC to fall back to
    the default ALC for those assemblies, ensuring a single type handle across the process.

    Set $(DisableAzFuncTestFrameworkFilter)=true in a project to opt out.
  -->
  <Target Name="AzFuncTestFramework_FilterExtensions"
          AfterTargets="Build"
          Condition="'$(DisableAzFuncTestFrameworkFilter)' != 'true'">

    <PropertyGroup>
      <_AzFuncExtDir>$(OutDir).azurefunctions\</_AzFuncExtDir>
    </PropertyGroup>

    <!-- Collect extension DLLs that duplicate a DLL already in the main output directory. -->
    <ItemGroup Condition="Exists('$(_AzFuncExtDir)')">
      <_AzFuncExtDlls Include="$(_AzFuncExtDir)*.dll" />
    </ItemGroup>

    <ItemGroup>
      <_DllsToRemove Include="@(_AzFuncExtDlls)"
                     Condition="Exists('$(OutDir)%(Filename)%(Extension)')" />
    </ItemGroup>

    <Message Text="AzFuncTestFramework: Removing %(Filename)%(Extension) from .azurefunctions to prevent ALC type-identity issues"
             Importance="normal"
             Condition="'@(_DllsToRemove)' != ''" />

    <Delete Files="@(_DllsToRemove)" />

  </Target>
</Project>
