<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Description>Table input binding support for the Azure Functions Test Framework. Enables injecting fake Azure Table Storage data for functions with [TableInput] parameters in integration tests.</Description>
    <PackageTags>azure-functions testing dotnet integration-testing table-input</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\AzureFunctions.TestFramework.Core\AzureFunctions.TestFramework.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Functions.Worker.Extensions.Tables" />
  </ItemGroup>

</Project>
