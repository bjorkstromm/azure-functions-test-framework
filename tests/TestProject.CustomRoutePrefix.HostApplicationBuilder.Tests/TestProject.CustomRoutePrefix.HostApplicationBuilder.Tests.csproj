<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    <RootNamespace>TestProject</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\Shared\Tests\GlobalUsings.cs" Link="Shared\GlobalUsings.cs" />
    <Compile Include="..\Shared\Tests\XUnitLoggerProvider.cs" Link="Shared\XUnitLoggerProvider.cs" />
    <Compile Include="..\Shared\Tests\TestHostTestBase.cs" Link="Shared\TestHostTestBase.cs" />
    <Compile Include="..\Shared\Tests\CustomRoutePrefixTestsBase.cs" Link="Shared\CustomRoutePrefixTestsBase.cs" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Azure.Functions.Worker" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit.v3.mtp-v2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\TestProject.CustomRoutePrefix.HostApplicationBuilder\TestProject.CustomRoutePrefix.HostApplicationBuilder.csproj" />
    <ProjectReference Include="..\..\src\AzureFunctions.TestFramework.Core\AzureFunctions.TestFramework.Core.csproj" />
    <ProjectReference Include="..\..\src\AzureFunctions.TestFramework.Http\AzureFunctions.TestFramework.Http.csproj" />
  </ItemGroup>
</Project>
